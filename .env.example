PUBLIC_HOST=localhost
LAN_HOST=localhost
HTTPS_PORT=38001
HTTP_PORT=80
TURN_HOST=localhost
TURN_EXTERNAL_IP=
TURN_PORT=38002
TURN_MIN_PORT=38010
TURN_MAX_PORT=38050
TURN_REALM=remote-emulator
TURN_USER=remote
TURN_SHARED_SECRET=change-me
TURN_CREDENTIAL_TTL_SECONDS=3600
TURN_ICE_TRANSPORT_POLICY=relay
TURN_DENY_PRIVATE_PEERS=true
TURN_USER_QUOTA=2
TURN_TOTAL_QUOTA=20
TURN_MAX_BPS=2500000
