EMU_WIDTH=1080
EMU_HEIGHT=1920
EMU_DISPLAY=0
INPUT_MODE=unary
GRPC_WEB_URI=/grpc
ENABLE_MOUSE_INPUT=false
TOUCH_DEBUG=false
APP_CONTROL_ENABLED=true
EMULATOR_ADB_SERIAL=emulator:5555
ADB_BIN=adb
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
DEBUG_ROUTES=false
CADDY_ACME_EMAIL=
CADDY_ACME_DNS_CLOUDFLARE=false
